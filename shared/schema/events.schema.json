{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/sci-agent/events.schema.json",
  "title": "SciAgent WebSocket Event Schema",
  "description": "Unified WebSocket event schema for SciAgent topic and admin streams.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "ts",
    "topicId",
    "runId",
    "agentId",
    "kind",
    "severity",
    "summary"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "pattern": "^[a-fA-F0-9-]{8,}$",
      "description": "Event unique identifier (uuid-like)."
    },
    "ts": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in milliseconds."
    },
    "topicId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "agentId": {
      "type": "string",
      "enum": ["review", "ideation", "experiment"]
    },
    "kind": {
      "type": "string",
      "enum": [
        "agent_status_updated",
        "event_emitted",
        "artifact_created",
        "message_created",
        "agent_subtasks_updated",
        "module_started",
        "module_finished",
        "module_skipped",
        "module_failed",
        "approval_required",
        "approval_resolved",
        "admin_metrics"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "error"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "description": "Extension fields, interpreted by event kind.",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactId", "name", "uri", "contentType"],
        "properties": {
          "artifactId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "contentType": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "traceId": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "artifact_created"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["artifacts"]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "message_created"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["message"],
            "properties": {
              "message": {
                "type": "object",
                "additionalProperties": false,
                "required": ["messageId", "topicId", "agentId", "role", "content", "ts"],
                "properties": {
                  "messageId": {
                    "type": "string",
                    "minLength": 8
                  },
                  "topicId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "runId": {
                    "type": ["string", "null"]
                  },
                  "agentId": {
                    "type": "string",
                    "enum": ["review", "ideation", "experiment"]
                  },
                  "role": {
                    "type": "string",
                    "enum": ["user", "assistant", "system"]
                  },
                  "content": {
                    "type": "string",
                    "minLength": 1
                  },
                  "ts": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "agent_subtasks_updated"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["subtasks", "subtaskCount", "stage"],
            "properties": {
              "subtasks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "name", "status", "progress"],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "status": {
                      "type": "string",
                      "enum": ["pending", "running", "completed", "failed"]
                    },
                    "progress": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  }
                }
              },
              "subtaskCount": {
                "type": "integer",
                "minimum": 0
              },
              "stage": {
                "type": "string",
                "enum": ["review", "ideation", "experiment", "feedback"]
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "module_started"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": ["runId", "module", "model", "thinkingMode", "online"],
            "properties": {
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "topicId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "enum": ["review", "ideation", "experiment"]
              },
              "model": {
                "type": "string",
                "minLength": 1
              },
              "thinkingMode": {
                "type": "string",
                "enum": ["normal", "deep"]
              },
              "online": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "module_finished"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": ["runId", "module", "status", "artifactNames"],
            "properties": {
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "enum": ["review", "ideation", "experiment"]
              },
              "status": {
                "type": "string",
                "enum": ["success", "failed", "skipped"]
              },
              "artifactNames": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "metrics": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "module_skipped"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": ["runId", "module", "reason"],
            "properties": {
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "enum": ["review", "ideation", "experiment"]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "module_failed"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": ["runId", "module", "error"],
            "properties": {
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "enum": ["review", "ideation", "experiment"]
              },
              "error": {
                "type": "object",
                "additionalProperties": false,
                "required": ["message"],
                "properties": {
                  "message": {
                    "type": "string",
                    "minLength": 1
                  },
                  "code": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "retryable": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "approval_required"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": ["runId", "module", "summary"],
            "properties": {
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "enum": ["review", "ideation", "experiment"]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "artifactName": {
                "type": "string",
                "minLength": 1
              },
              "draftArtifact": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "mimeType": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sizeBytes": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "approval_resolved"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": ["runId", "module", "approved"],
            "properties": {
              "runId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "enum": ["review", "ideation", "experiment"]
              },
              "approved": {
                "type": "boolean"
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "admin_metrics"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "ts",
              "activeRuns",
              "runsLast5m",
              "eventsLast5m",
              "moduleInFlight",
              "approvalsPending",
              "errorRateLast5m"
            ],
            "properties": {
              "ts": {
                "type": ["integer", "string"]
              },
              "activeRuns": {
                "type": "integer",
                "minimum": 0
              },
              "runsLast5m": {
                "type": "integer",
                "minimum": 0
              },
              "eventsLast5m": {
                "type": "integer",
                "minimum": 0
              },
              "moduleInFlight": {
                "type": "object",
                "additionalProperties": false,
                "required": ["review", "ideation", "experiment"],
                "properties": {
                  "review": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "ideation": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "experiment": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              },
              "approvalsPending": {
                "type": "integer",
                "minimum": 0
              },
              "errorRateLast5m": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    }
  ]
}
